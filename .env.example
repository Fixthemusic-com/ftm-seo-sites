# Environment variables for local development
# Copy to .env and fill in values

# Which site to build (weddingbandsitaly | weddingmusicbanditaly)
SITE_ID=weddingbandsitaly

# FTM API base URL (server-side, build-time fetches)
FTM_API_BASE=https://staging.fixthemusic.com

# Site auth token (from ExternalSiteToken in Django admin)
FTM_SITE_TOKEN=

# Client-side vars (prefixed with PUBLIC_ for Astro)
PUBLIC_FTM_API_BASE=https://staging.fixthemusic.com
PUBLIC_FTM_SITE_TOKEN=

# OpenRouter API key for AI profile rewrites (deepseek/deepseek-v4-flash:nitro)
OPENROUTER_API_KEY=
