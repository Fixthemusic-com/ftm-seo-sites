---
import type { Band } from '../lib/types';

interface Props {
  band: Band;
}

const { band } = Astro.props;
const priceDisplay =
  band.price_low && band.price_high
    ? `EUR ${band.price_low.toLocaleString()} - ${band.price_high.toLocaleString()}`
    : band.price_low
      ? `From EUR ${band.price_low.toLocaleString()}`
      : null;
---

<a
  href={`/bands/${band.slug}/`}
  class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300"
>
  <!-- Image -->
  <div class="aspect-[4/3] overflow-hidden bg-gray-100">
    {band.profile_image ? (
      <img
        src={band.profile_image}
        alt={band.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-gray-400">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
        </svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-4">
    <h3 class="font-heading font-semibold text-lg group-hover:text-primary transition-colors">
      {band.name}
    </h3>
    {band.kicker && (
      <p class="text-sm text-gray-500 mt-1 line-clamp-1">{band.kicker}</p>
    )}
    <div class="flex items-center justify-between mt-3">
      <div class="flex items-center gap-1">
        {band.average_rating && (
          <>
            <span class="text-accent font-semibold">{band.average_rating.toFixed(1)}</span>
            <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span class="text-xs text-gray-400">({band.review_count})</span>
          </>
        )}
      </div>
      {priceDisplay && (
        <span class="text-sm font-medium text-gray-600">{priceDisplay}</span>
      )}
    </div>
  </div>
</a>
