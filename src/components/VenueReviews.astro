---
/**
 * Shared venue reviews component.
 * - On venue detail pages: showVenue=false (venue name is already the page title)
 * - On location/region pages: showVenue=true (reviews from multiple venues)
 */
import type { VenueReview } from '../lib/api';

interface Props {
  reviews: VenueReview[];
  total: number;
  showVenue?: boolean;
  heading?: string;
}

const {
  reviews = [],
  total = 0,
  showVenue = false,
  heading = 'Venue Reviews',
} = Astro.props;

// Calculate aggregate rating
const rated = reviews.filter(r => r.rating != null);
const avgRating = rated.length > 0
  ? (rated.reduce((sum, r) => sum + (r.rating ?? 0), 0) / rated.length)
  : 0;
const ratingCount = rated.length;

// Star rendering helper
function stars(rating: number | null): string {
  if (rating == null) return '';
  const full = Math.floor(rating);
  const half = rating - full >= 0.5;
  let s = '';
  for (let i = 0; i < full; i++) s += '★';
  if (half) s += '½';
  return s;
}

// Note: AggregateRating schema REMOVED — standalone @type is invalid.
// Rating data belongs on the parent Place or MusicGroup schema, not as a bare script tag.
---

{reviews.length > 0 && (
  <section class="mb-10" aria-label={heading}>
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-heading text-2xl font-bold">{heading}</h2>
      {ratingCount > 0 && (
        <div class="flex items-center gap-2">
          <span class="text-amber-500 text-lg">{stars(avgRating)}</span>
          <span class="text-sm text-gray-600">
            {avgRating.toFixed(1)} · {ratingCount} review{ratingCount !== 1 ? 's' : ''}
          </span>
        </div>
      )}
    </div>

    <div class="space-y-6">
      {reviews.map((review) => (
        <article class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
          <div class="flex items-start justify-between mb-3">
            <div>
              <div class="flex items-center gap-2 mb-1">
                {review.rating != null && (
                  <span class="text-amber-500">{stars(review.rating)}</span>
                )}
                <span class="font-semibold text-gray-900">{review.author}</span>
              </div>
              <div class="text-sm text-gray-500 flex flex-wrap gap-x-3">
                <a href={`/bands/${review.band_slug}/`} class="text-primary hover:underline font-medium">
                  {review.band_name}
                </a>
                {showVenue && review.venue_name && review.venue_slug && (
                  <span>
                    at <a href={`/venues/${review.venue_slug}/`} class="hover:underline">{review.venue_name.split(',')[0]}</a>
                  </span>
                )}
                {review.time_published && (
                  <time datetime={review.time_published}>
                    {new Date(review.time_published).toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                  </time>
                )}
              </div>
              {review.event_string && (
                <p class="text-xs text-gray-400 mt-1">{review.event_string}</p>
              )}
            </div>
          </div>

          <div class="prose prose-sm max-w-none text-gray-700" set:html={review.text_html} />

          {review.response && (
            <div class="mt-4 ml-4 border-l-2 border-primary/20 pl-4">
              <p class="text-xs font-semibold text-primary mb-1">Response from {review.band_name}</p>
              <div class="prose prose-sm max-w-none text-gray-600" set:html={review.response.message_rendered} />
            </div>
          )}
        </article>
      ))}
    </div>

    {total > reviews.length && (
      <p class="text-center text-sm text-gray-500 mt-6">
        Showing {reviews.length} of {total} reviews
      </p>
    )}
  </section>
)}
