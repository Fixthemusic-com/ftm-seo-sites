---
import BaseLayout from './BaseLayout.astro';
import BandCard from '../components/BandCard.astro';
import PopularVenues from '../components/PopularVenues.astro';
import VenueReviews from '../components/VenueReviews.astro';
import { siteConfig } from '../lib/config';
import type { Band, VenueListItem } from '../lib/types';
import type { VenueReview } from '../lib/api';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  regionName: string;
  region: string;
  bands: Band[];
  totalBands: number;
  venues?: VenueListItem[];
  regionReviews?: { items: VenueReview[]; count: number };
  leadHtml?: string;
  bodyHtml?: string;
}

const {
  title,
  description,
  heroTitle,
  heroSubtitle,
  regionName,
  region,
  bands,
  totalBands,
  venues = [],
  regionReviews = { items: [], count: 0 },
  leadHtml = '',
  bodyHtml = '',
} = Astro.props;

// Schema.org structured data
const schemaOrg = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description: description,
    url: Astro.url.href,
    isPartOf: {
      '@type': 'WebSite',
      name: siteConfig.name,
      url: siteConfig.domain,
    },
    about: {
      '@type': 'Place',
      name: regionName,
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'IT',
        addressRegion: regionName,
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `Wedding Bands in ${regionName}`,
    numberOfItems: totalBands,
    itemListElement: bands.slice(0, 12).map((band, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'MusicGroup',
        name: band.name,
        url: `https://${siteConfig.domain}/bands/${band.slug}/`,
        ...(band.location ? { location: { '@type': 'Place', name: band.location } } : {}),
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `https://${siteConfig.domain}/` },
      { '@type': 'ListItem', position: 2, name: 'Locations', item: `https://${siteConfig.domain}/locations/` },
      { '@type': 'ListItem', position: 3, name: regionName, item: Astro.url.href },
    ],
  },
];

// Extract FAQ items from bodyHtml for FAQPage schema
const faqItems: { question: string; answer: string }[] = [];
const faqMatch = bodyHtml.match(/<h[2-4][^>]*>[^<]*(?:faq|frequently asked|questions?)[^<]*<\/h[2-4]>([\s\S]*?)(?=<h2|$)/i);
if (faqMatch) {
  const faqSection = faqMatch[1];
  const qaRegex = /<h[3-4][^>]*>(.*?)<\/h[3-4]>\s*([\s\S]*?)(?=<h[3-4]|$)/gi;
  let m;
  while ((m = qaRegex.exec(faqSection)) !== null) {
    const question = m[1].replace(/<[^>]*>/g, '').trim();
    const answer = m[2].replace(/<[^>]*>/g, '').trim();
    if (question && answer && question.includes('?')) {
      faqItems.push({ question, answer });
    }
  }
}
// Also try: <strong>Question?</strong><p>Answer</p> pattern
if (faqItems.length === 0) {
  const altRegex = /<(?:strong|b)[^>]*>([^<]*\?)<\/(?:strong|b)>\s*(?:<p[^>]*>)?([\s\S]*?)(?:<\/p>)?/gi;
  let m;
  while ((m = altRegex.exec(bodyHtml)) !== null) {
    const question = m[1].trim();
    const answer = m[2].replace(/<[^>]*>/g, '').trim();
    if (question && answer) faqItems.push({ question, answer });
  }
}
if (faqItems.length > 0) {
  schemaOrg.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map(item => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  } as any);
}
---

<BaseLayout title={title} description={description}>
  <!-- Schema.org -->
  {schemaOrg.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- Hero -->
  <section class="bg-primary text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <nav class="text-sm opacity-70 mb-4">
        <a href="/" class="hover:opacity-100">Home</a>
        <span class="mx-2">›</span>
        <a href="/locations/" class="hover:opacity-100">Locations</a>
        <span class="mx-2">›</span>
        <span>{regionName}</span>
      </nav>
      <h1 class="font-heading text-3xl md:text-5xl font-bold mb-4">
        {heroTitle}
      </h1>
      <p class="text-lg md:text-xl opacity-90 mb-6 max-w-2xl mx-auto">
        {heroSubtitle}
      </p>

      <p class="text-sm opacity-70">
        {totalBands} verified acts available in {regionName}
      </p>
    </div>
  </section>

  <!-- Sticky mini-TOC -->
  <div class="sticky top-16 z-30 bg-white/95 backdrop-blur shadow-sm border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 py-2 flex gap-2 overflow-x-auto text-sm whitespace-nowrap scrollbar-hide">
      <a href="#lead" class="text-primary hover:underline">About {regionName}</a>
      {venues.length > 0 && <a href="#venues" class="text-gray-600 hover:text-primary">Venues</a>}
      {regionReviews.items.length > 0 && <a href="#reviews" class="text-gray-600 hover:text-primary">Reviews</a>}
      {bands.length > 0 && <a href="#bands" class="text-gray-600 hover:text-primary">Bands</a>}
      <a href="#budget" class="text-gray-600 hover:text-primary">Budget</a>
      <a href="#faq" class="text-gray-600 hover:text-primary">FAQ</a>
      <a href="/enquire/" class="ml-auto bg-primary text-white px-3 py-1 rounded-md font-semibold hover:opacity-90 flex-shrink-0">Get a quote</a>
    </div>
  </div>

  <!-- Article lead (top ~600 words) -->
  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12" id="lead">
    <div class="prose prose-lg max-w-none" set:html={leadHtml} />
  </article>

  <!-- Popular Venues -->
  {venues.length > 0 && (
    <section class="bg-gray-50 py-12" id="venues">
      <div class="max-w-7xl mx-auto px-4">
        <PopularVenues venues={venues} regionName={regionName} maxItems={6} regionSlug={region} />
      </div>
    </section>
  )}

  <!-- Venue Reviews -->
  {regionReviews.items.length > 0 && (
    <section class="bg-white py-12" id="reviews">
      <div class="max-w-4xl mx-auto px-4">
        <VenueReviews
          reviews={regionReviews.items}
          total={regionReviews.count}
          showVenue={true}
          heading={`Venue Reviews in ${regionName}`}
        />
      </div>
    </section>
  )}

  <!-- Featured Bands -->
  {bands.length > 0 && (
    <section class="bg-gray-50 py-16" id="bands">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="font-heading text-3xl font-bold text-center mb-4">
          Featured Bands in {regionName}
        </h2>
        <p class="text-center text-gray-600 mb-10 max-w-2xl mx-auto">
          Browse our hand-picked selection of live wedding bands available for events in {regionName}.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {bands.slice(0, 8).map((band) => (
            <BandCard band={band} />
          ))}
        </div>
        <div class="text-center mt-8">
          <a
            href={`/browse/?search=${encodeURIComponent(regionName)}`}
            class="inline-block bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            View All Bands in {regionName}
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Collapsed article body (budget, SIAE, traditions, FAQ) -->
  {bodyHtml && (
    <details class="max-w-4xl mx-auto px-4 sm:px-6 py-8 group" id="more">
      <summary class="cursor-pointer list-none flex items-center justify-between py-4 px-6 bg-gray-50 rounded-lg hover:bg-gray-100 transition font-heading text-xl font-semibold">
        <span>Read the full {regionName} wedding guide</span>
        <span class="text-primary text-sm group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <article class="prose prose-lg max-w-none mt-8" id="body">
        <div set:html={bodyHtml} />
      </article>
    </details>
  )}

  <!-- CTA -->
  <section class="bg-accent text-white py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl font-bold mb-4">
        Planning a Wedding in {regionName}?
      </h2>
      <p class="text-lg opacity-90 mb-8">
        Tell us about your wedding and we'll recommend the perfect live music for your {regionName} celebration.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/enquire/"
          class="bg-white text-primary px-8 py-3 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity"
        >
          Get a Free Quote
        </a>
        <a
          href="/browse/"
          class="border border-white/40 text-white px-8 py-3 rounded-lg text-lg hover:bg-white/10 transition-colors"
        >
          Browse All Bands
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hide scrollbar on the TOC strip while still allowing horizontal scroll */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  /* Native <details> marker override */
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
</style>
