---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../lib/config';
---

<BaseLayout
  title="Make an Enquiry"
  description={`Get a quote from the best wedding bands in Italy. Tell us about your event and we'll match you with perfect entertainment.`}
>
  <section class="py-10 max-w-2xl mx-auto px-4">
    <h1 class="font-heading text-3xl font-bold mb-2">Make an Enquiry</h1>
    <p class="text-gray-600 mb-8">
      Tell us about your wedding and we'll connect you with the perfect entertainment.
    </p>

    <form id="enquiry-form" class="space-y-6">
      <!-- Contact -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
            placeholder="John Smith"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
            placeholder="john@example.com"
          />
        </div>
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="+44 7700 900000"
        />
      </div>

      <!-- Event details -->
      <div>
        <label for="location" class="block text-sm font-medium text-gray-700 mb-1">
          Event Location <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="location"
          name="location"
          required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="Lake Como, Italy"
        />
        <input type="hidden" id="location_place_id" name="location_place_id" />
      </div>

      <div>
        <label for="event_date" class="block text-sm font-medium text-gray-700 mb-1">Event Date</label>
        <input
          type="date"
          id="event_date"
          name="event_date"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
          Tell us about your event
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="Describe your wedding, music preferences, number of guests..."
        ></textarea>
      </div>

      <!-- Hidden fields -->
      <input type="hidden" name="source_site" value={siteConfig.sourceSite} />
      <input type="hidden" id="act" name="act" value="" />

      <button
        type="submit"
        class="w-full bg-accent text-white px-8 py-3 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity"
      >
        Send Enquiry
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="success-msg" class="hidden mt-8 bg-green-50 border border-green-200 rounded-lg p-6 text-center">
      <svg class="w-12 h-12 text-green-500 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h2 class="font-heading text-2xl font-bold text-green-800">Enquiry Sent!</h2>
      <p class="text-green-700 mt-2">We'll be in touch within 24 hours with band recommendations.</p>
    </div>

    <!-- Error message (hidden by default) -->
    <div id="error-msg" class="hidden mt-4 bg-red-50 border border-red-200 rounded-lg p-4 text-red-700">
      <p>Something went wrong. Please try again or email us directly.</p>
    </div>
  </section>

  <script>
    const form = document.getElementById('enquiry-form') as HTMLFormElement;
    const successMsg = document.getElementById('success-msg')!;
    const errorMsg = document.getElementById('error-msg')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');

      const data = new FormData(form);
      const actValue = (data.get('act') as string) || '';
      const payload = {
        email: data.get('email'),
        name: data.get('name') || undefined,
        phone: data.get('phone') || undefined,
        location: data.get('location'),
        location_place_id: data.get('location_place_id') || undefined,
        event_date: data.get('event_date') || undefined,
        message: data.get('message') || undefined,
        act: actValue ? actValue.split(',') : [],
        source_site: data.get('source_site'),
      };

      try {
        const apiBase = import.meta.env.PUBLIC_FTM_API_BASE || 'https://www.fixthemusic.com';
        const token = import.meta.env.PUBLIC_FTM_SITE_TOKEN || '';

        const res = await fetch(`${apiBase}/api-v2/booking/external/enquiries/`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
        } else {
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>
