---
import BaseLayout from '../layouts/BaseLayout.astro';
import BandCard from '../components/BandCard.astro';
import { siteConfig } from '../lib/config';
import { getBands, getCategories } from '../lib/api';

// Build-time: fetch initial band list and categories
const [bandsResult, categories] = await Promise.all([
  getBands({ region: siteConfig.regionId, page_size: 24 }),
  getCategories(),
]);

const bands = bandsResult.items;
---

<BaseLayout
  title={`Browse Wedding Bands & Entertainment in Italy`}
  description={`Browse ${bandsResult.count}+ wedding bands and entertainment acts available in Italy. Filter by category, budget, and style.`}
>
  <section class="py-10">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="font-heading text-3xl md:text-4xl font-bold mb-2">
        Browse Wedding Entertainment
      </h1>
      <p class="text-gray-600 mb-8">
        {bandsResult.count} acts available in Italy
      </p>

      <!-- Filters (server-rendered, client-side search handled by URL params) -->
      <div class="flex flex-wrap gap-3 mb-8">
        <a
          href="/browse/"
          class="px-4 py-2 rounded-full text-sm font-medium bg-primary text-white"
        >
          All
        </a>
        {categories.slice(0, 10).map((cat) => (
          <a
            href={`/browse/?category=${cat.slug}`}
            class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors"
          >
            {cat.name} ({cat.num_bands})
          </a>
        ))}
      </div>

      <!-- Band grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {bands.map((band) => (
          <BandCard band={band} />
        ))}
      </div>

      <!-- Pagination placeholder -->
      {bandsResult.num_pages > 1 && (
        <div class="mt-12 flex justify-center gap-2">
          {Array.from({ length: Math.min(bandsResult.num_pages, 10) }, (_, i) => (
            <a
              href={`/browse/?page=${i + 1}`}
              class={`px-4 py-2 rounded-lg text-sm font-medium ${
                i === 0
                  ? 'bg-primary text-white'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
              } transition-colors`}
            >
              {i + 1}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
