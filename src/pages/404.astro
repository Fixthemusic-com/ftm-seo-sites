---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <h1 class="font-heading text-6xl font-bold text-primary mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">
      The page you're looking for doesn't exist — it may have been moved or removed.
    </p>
    <div class="space-y-3">
      <a href="/" class="block text-primary hover:underline font-semibold">← Back to home</a>
      <a href="/browse/" class="block text-gray-500 hover:text-primary transition-colors">Browse wedding bands</a>
      <a href="/locations/" class="block text-gray-500 hover:text-primary transition-colors">Explore locations</a>
      <a href="/venues/" class="block text-gray-500 hover:text-primary transition-colors">View wedding venues</a>
      <a href="/blog/" class="block text-gray-500 hover:text-primary transition-colors">Read our guides</a>
    </div>
  </section>
</BaseLayout>
