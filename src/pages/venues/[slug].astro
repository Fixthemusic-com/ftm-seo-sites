---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BandCard from '../../components/BandCard.astro';
import VenueReviews from '../../components/VenueReviews.astro';
import { siteConfig } from '../../lib/config';
import { getVenues, getVenue, getBand, getVenueReviews } from '../../lib/api';
import type { VenueDetail, VenueListItem } from '../../lib/types';
import { venueShortName, venueTown, monthName } from '../../lib/types';

export async function getStaticPaths() {
  // Fetch all venues with 5+ bookings
  const venues = await getVenues({ min_bookings: 5, limit: 500 });

  return venues.map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

const { slug } = Astro.params;
const venue: VenueDetail = await getVenue(slug!);

const name = venueShortName(venue.canonical_name);
const town = venueTown(venue.canonical_name);

// Build breadcrumbs from canonical_name parts
const addressParts = venue.canonical_name.split(',').map(p => p.trim()).filter(Boolean);
// Typically: [Venue Name, Street, Town, Province of X, Italy]
const provincePart = addressParts.find(p => p.startsWith('Province of') || p.startsWith('Metropolitan City of')) || '';
const townPart = addressParts.length >= 3 ? addressParts[addressParts.length - 3] : town;

// Fetch top bands (up to 4 that exist on this site)
let topBands = [];
if (venue.top_bands && venue.top_bands.length > 0) {
  for (const tb of venue.top_bands.slice(0, 8)) {
    try {
      const band = await getBand(tb.slug);
      if (band) topBands.push({ ...band, bookingCount: tb.count });
    } catch {
      // Band may not be in the region
    }
  }
  topBands = topBands.slice(0, 4);
}

// Format price display
const currency = venue.price_currency === 'EUR' ? '€' : venue.price_currency || '€';
const priceDisplay = venue.price_range_low && venue.price_range_high
  ? `${currency}${venue.price_range_low.toLocaleString()} – ${currency}${venue.price_range_high.toLocaleString()}`
  : venue.price_range_low
    ? `From ${currency}${venue.price_range_low.toLocaleString()}`
    : null;

// Format curfew (API returns "02:00:00" time format)
function formatCurfew(t: string | null): string {
  if (!t) return '';
  const parts = t.split(':');
  let h = parseInt(parts[0], 10);
  const m = parts[1] || '00';
  if (h === 0) return m !== '00' ? '12:' + m + 'am' : 'Midnight';
  if (h < 12) return h + (m !== '00' ? ':' + m : '') + 'am';
  if (h === 12) return '12' + (m !== '00' ? ':' + m : '') + 'pm';
  return (h - 12) + (m !== '00' ? ':' + m : '') + 'pm';
}
const curfewDisplay = formatCurfew(venue.curfew_time);

// Strip internal pipeline references and unsuitable phrases from venue text
function stripInternalRefs(text: string | null): string {
  if (!text) return '';
  return text
    // Pipeline message references
    .replace(/\(e\.g\.,?\s*(?:messages?\s+)?[\d, ]+\)/gi, '')
    .replace(/\((?:messages?\s+)?[\d, ]+\)/gi, '')
    .replace(/\bmessages?\s+\d[\d,]*\b/gi, '')
    // Booking count patterns embedded in prose
    .replace(/,\s*with\s+\d+\s+bookings?\s+across\s+\d+\s+unique\s+bands?\s+between\s+\d+\s+and\s+\d+/gi, '')
    .replace(/with\s+\d+\s+bookings?\s+across\s+\d+\s+unique\s+bands?\s+between\s+\d+\s+and\s+\d+/gi, '')
    .replace(/across\s+\d+\s+unique\s+bands?\s+between\s+\d+\s+and\s+\d+/gi, '')
    .replace(/,\s*\d+\s+bookings?\b/gi, '')
    // Platform references
    .replace(/\bthrough\s+FixTheMusic\b/gi, '')
    .replace(/\bbooked\s+through\s+\w+\b/gi, '')
    // Analytical report phrasing
    .replace(/\bthe correspondence reveals\b/gi, '')
    .replace(/\bthe data shows\b/gi, '')
    // Cleanup
    .replace(/\s{2,}/g, ' ')
    .replace(/,\s*\./g, '.')
    .replace(/^,\s*/g, '')
    .trim();
}

// Clean curfew notes
const curfewNotes = venue.curfew_notes ? stripInternalRefs(venue.curfew_notes) : null;

// Clean editorial summary
const editorialClean = venue.editorial_summary ? stripInternalRefs(venue.editorial_summary) : null;
const venueDescClean = venue.venue_description ? stripInternalRefs(venue.venue_description) : null;

// Clean all logistics-related notes
const loadInNotes = venue.load_in_notes ? stripInternalRefs(venue.load_in_notes) : null;
const powerNotes = venue.power_notes ? stripInternalRefs(venue.power_notes) : null;
const soundNotes = venue.sound_notes ? stripInternalRefs(venue.sound_notes) : null;
const rainBackupNotes = venue.rain_backup_notes ? stripInternalRefs(venue.rain_backup_notes) : null;
const setupAreasCleaned = Array.isArray(venue.setup_areas) 
  ? venue.setup_areas.map((a: string) => a ? stripInternalRefs(a) : '').filter(Boolean)
  : [];

// Check if logistics has actual content
const hasLoadIn = loadInNotes && loadInNotes.trim().length > 0;
const hasPower = powerNotes && powerNotes.trim().length > 0;
const hasSound = soundNotes && soundNotes.trim().length > 0;
const hasRainBackup = rainBackupNotes && rainBackupNotes.trim().length > 0;
const hasSetupAreas = setupAreasCleaned.length > 0;
const hasIndoorBackup = venue.has_indoor_backup === true;
const hasLogistics = hasLoadIn || hasPower || hasSound || hasRainBackup || hasSetupAreas || hasIndoorBackup;

// Top music categories
const categories = venue.top_categories
  ? Object.entries(venue.top_categories).sort((a, b) => (b[1] as number) - (a[1] as number)).slice(0, 5)
  : [];

// Peak months
const peakMonths = (venue.peak_months || []).map(m => monthName(m)).filter(Boolean);

// Fetch venue reviews
let venueReviews = { items: [] as any[], count: 0 };
try {
  venueReviews = await getVenueReviews(slug!, 10);
} catch {
  // Reviews may not exist for all venues
}

// Schema.org Place structured data
// Calculate aggregate rating for schema
const ratedReviews = venueReviews.items.filter((r: any) => r.rating != null);
const avgReviewRating = ratedReviews.length > 0
  ? (ratedReviews.reduce((sum: number, r: any) => sum + r.rating, 0) / ratedReviews.length)
  : 0;

const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: venue.canonical_name,
  description: venueDescClean || editorialClean || `${name} is a wedding venue in ${townPart || 'Italy'} popular for live music events.`,
  geo: venue.lat && venue.lng ? {
    '@type': 'GeoCoordinates',
    latitude: venue.lat,
    longitude: venue.lng,
  } : undefined,
  address: {
    '@type': 'PostalAddress',
    addressLocality: townPart,
    addressRegion: provincePart.replace('Province of ', '').replace('Metropolitan City of ', ''),
    addressCountry: 'IT',
  },
  url: `https://${siteConfig.domain}/venues/${venue.slug}/`,
  ...(ratedReviews.length > 0 ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: avgReviewRating.toFixed(1),
      reviewCount: venueReviews.count,
      bestRating: '5',
      worstRating: '1',
    },
  } : {}),
};

// BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://${siteConfig.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `https://${siteConfig.domain}/locations/` },
    { '@type': 'ListItem', position: 3, name: 'Venues', item: `https://${siteConfig.domain}/venues/` },
    { '@type': 'ListItem', position: 4, name: name },
  ],
};

const pageTitle = `${name} — Wedding Venue${townPart ? ' in ' + townPart : ''} | Live Music`;
const pageDesc = venueDescClean
  ? venueDescClean.slice(0, 160)
  : editorialClean
    ? editorialClean.slice(0, 160)
    : `${name} in ${townPart || 'Italy'}. ${peakMonths.length ? 'Peak months: ' + peakMonths.slice(0, 3).join(', ') + '.' : ''} ${priceDisplay ? 'Typical music budget: ' + priceDisplay + '.' : ''} ${curfewDisplay ? 'Music curfew: ' + curfewDisplay + '.' : ''}`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="max-w-5xl mx-auto px-4 py-10">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-1">›</span>
      <a href="/venues/" class="hover:text-primary">Venues</a>
      <span class="mx-1">›</span>
      <span class="text-gray-800">{name}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold mb-2">{name}</h1>
      {venue.formatted_address && <p class="text-lg text-gray-600 mb-2">{venue.formatted_address}</p>}
      {!venue.formatted_address && townPart && <p class="text-lg text-gray-600 mb-2">{addressParts.join(', ')}</p>}
      <div class="flex flex-wrap items-center gap-3 mt-3 text-sm">
        {venue.website_url && (
          <a href={venue.website_url} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-primary hover:underline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Website
          </a>
        )}
        {venue.phone_number && (
          <span class="inline-flex items-center gap-1 text-gray-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {venue.phone_number}
          </span>
        )}
        {venue.unique_band_count > 0 && (
          <span class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1 rounded-full text-sm font-medium">
            {venue.unique_band_count} different bands performed here
          </span>
        )}
      </div>
    </header>

    <!-- Photo Gallery -->
    {Array.isArray(venue.google_photos) && venue.google_photos.length > 0 && (
      <section class="mb-10">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2 rounded-xl overflow-hidden">
          {venue.google_photos.slice(0, 6).map((photo: string, i: number) => (
            <a href={photo} target="_blank" rel="noopener noreferrer"
              class={`block relative overflow-hidden ${i === 0 ? 'md:col-span-2 md:row-span-2' : ''}`}>
              <img
                src={photo}
                alt={`${name} photo ${i + 1}`}
                class={`w-full object-cover hover:scale-105 transition-transform duration-300 ${i === 0 ? 'h-48 md:h-[33.5rem]' : 'h-48 md:h-64'}`}
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Venue Description (Exa + LLM generated) - first major section -->
    {venueDescClean && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-4">About {name}</h2>
        <div class="prose prose-lg max-w-none" set:html={venueDescClean.replace(/\n/g, '<br>')} />
      </section>
    )}

    <!-- Editorial: What Performing Here Is Like (from correspondence) -->
    {editorialClean && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-4">What Performing Here Is Like</h2>
        <p class="text-sm text-gray-500 mb-3">Practical insights from musicians who have played at {name}</p>
        <div class="prose prose-lg max-w-none" set:html={editorialClean.replace(/\n/g, '<br>')} />
      </section>
    )}

    <!-- Key Stats Grid -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      {priceDisplay && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-xs uppercase tracking-wide text-gray-500 mb-1">Music Budget</div>
          <div class="text-lg font-semibold text-primary">{priceDisplay}</div>
        </div>
      )}
      {venue.guest_count_median && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-xs uppercase tracking-wide text-gray-500 mb-1">Typical Guests</div>
          <div class="text-lg font-semibold">
            {venue.guest_count_min && venue.guest_count_max
              ? `${venue.guest_count_min}–${venue.guest_count_max}`
              : venue.guest_count_median}
          </div>
        </div>
      )}
      {curfewDisplay && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-xs uppercase tracking-wide text-gray-500 mb-1">Music Curfew</div>
          <div class="text-lg font-semibold">{curfewDisplay}</div>
          {venue.curfew_notes && curfewNotes && <div class="text-xs text-gray-500 mt-1">{curfewNotes}</div>}
        </div>
      )}
      {peakMonths.length > 0 && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-xs uppercase tracking-wide text-gray-500 mb-1">Peak Season</div>
          <div class="text-lg font-semibold">{peakMonths.slice(0, 3).join(', ')}</div>
        </div>
      )}
    </section>

    <!-- Music Categories -->
    {categories.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-4">Most Popular Music at {name}</h2>
        <div class="space-y-3">
          {categories.map(([catName, count]) => {
            const total = categories.reduce((sum, [, c]) => sum + (c as number), 0);
            const pct = Math.round(((count as number) / total) * 100);
            return (
              <div class="flex items-center gap-3">
                <div class="flex-1">
                  <div class="flex justify-between text-sm mb-1">
                    <span class="font-medium">{catName}</span>
                    <span class="text-gray-500">{pct}%</span>
                  </div>
                  <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full bg-primary rounded-full" style={`width: ${pct}%`} />
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Top Bands at This Venue -->
    {topBands.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-4">Top Bands at {name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {topBands.map((band: any) => (
            <BandCard band={band} />
          ))}
        </div>
      </section>
    )}

    <!-- Logistics & Practical Info -->
    {hasLogistics && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-4">Logistics for Musicians</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {hasLoadIn && (
            <div>
              <h3 class="font-semibold mb-2">Load-In & Access</h3>
              <p class="text-gray-600 text-sm">{loadInNotes}</p>
            </div>
          )}
          {hasPower && (
            <div>
              <h3 class="font-semibold mb-2">Power Supply</h3>
              <p class="text-gray-600 text-sm">{powerNotes}</p>
            </div>
          )}
          {hasSound && (
            <div>
              <h3 class="font-semibold mb-2">Sound Restrictions</h3>
              <p class="text-gray-600 text-sm">{soundNotes}</p>
            </div>
          )}
          {hasRainBackup && (
            <div>
              <h3 class="font-semibold mb-2">Rain Backup</h3>
              <p class="text-gray-600 text-sm">{rainBackupNotes}</p>
            </div>
          )}
          {hasSetupAreas && (
            <div>
              <h3 class="font-semibold mb-2">Performance Areas</h3>
              <ul class="text-gray-600 text-sm list-disc list-inside">
                {setupAreasCleaned.map((area: string) => <li>{area}</li>)}
              </ul>
            </div>
          )}
          {hasIndoorBackup && (
            <div>
              <h3 class="font-semibold mb-2">Indoor Backup</h3>
              <p class="text-gray-600 text-sm">Yes — indoor space available for rain or noise-sensitive events</p>
            </div>
          )}
        </div>
      </section>
    )}

    {/* Overtime */}
    {(venue.overtime_rate_low || venue.overtime_rate_high) && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-4">Additional Costs</h2>
        <div>
          <h3 class="font-semibold mb-2">Overtime Rate</h3>
          <p class="text-gray-600">
            {venue.overtime_rate_low && venue.overtime_rate_high
              ? `${currency}${venue.overtime_rate_low}–${currency}${venue.overtime_rate_high}/hour`
              : venue.overtime_rate_low
                ? `From ${currency}${venue.overtime_rate_low}/hour`
                : `${currency}${venue.overtime_rate_high}/hour`}
          </p>
        </div>
      </section>
    )}

    {/* Wedding Planners */}
    {venue.associated_planners && venue.associated_planners.length > 0 && (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold mb-2">Frequently Working With</h2>
        <p class="text-gray-600 mb-3 text-sm">These wedding planners have organised events at {name}:</p>
        <ul class="list-disc list-inside text-gray-700">
          {venue.associated_planners.map((planner: any) => <li>{typeof planner === 'string' ? planner : planner.name || planner.company || JSON.stringify(planner)}</li>)}
        </ul>
      </section>
    )}

    {/* Venue Reviews */}
    {venueReviews.items.length > 0 && (
      <VenueReviews
        reviews={venueReviews.items}
        total={venueReviews.count}
        showVenue={false}
        heading={`Reviews from Bands at ${name}`}
      />
    )}

    {/* CTA */}
    <section class="bg-primary/5 border border-primary/20 rounded-xl p-8 text-center mt-12">
      <h2 class="font-heading text-2xl font-bold mb-3">Planning a wedding at {name}?</h2>
      <p class="text-gray-600 mb-5">Get a tailored quote for live music matched to your event, venue, and budget.</p>
      <a href="/enquire/" class="inline-block bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary/90 transition">
        Get a Quote
      </a>
    </section>

    {/* Back link */}
    <div class="mt-8 text-center">
      <a href="/venues/" class="text-primary hover:underline">← Browse all wedding venues in Italy</a>
    </div>
  </article>
</BaseLayout>
