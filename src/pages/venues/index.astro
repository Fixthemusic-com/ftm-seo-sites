---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../lib/config';
import { getVenues } from '../../lib/api';
import { venueShortName, venueTown } from '../../lib/types';
import type { VenueListItem } from '../../lib/types';

let venues: VenueListItem[] = [];
try {
  venues = await getVenues({ min_bookings: 5, limit: 500 });
} catch (err: any) {
  console.warn(`Venues API unavailable (${err?.message || err}), showing empty venues page`);
}

// Group by province/admin region
const regionGroups: Record<string, VenueListItem[]> = {};
for (const v of venues) {
  const parts = v.canonical_name.split(',').map(p => p.trim());
  let region = 'Other';
  for (const part of parts) {
    if (part.startsWith('Province of ') || part.startsWith('Metropolitan City of ')) {
      region = part.replace('Province of ', '').replace('Metropolitan City of ', '');
      break;
    }
  }
  if (!regionGroups[region]) regionGroups[region] = [];
  regionGroups[region].push(v);
}

const sortedRegions = Object.entries(regionGroups)
  .map(([name, items]) => ({
    name,
    items: items.sort((a, b) => b.booking_count - a.booking_count),
  }))
  .sort((a, b) => b.items.length - a.items.length);

// Link to location pages where available
const locationSlugMap: Record<string, string> = {
  'Siena': 'siena',
  'Perugia': 'umbria',
  'Arezzo': 'tuscany',
  'Florence': 'florence',
  'Prato': 'tuscany',
  'Pisa': 'tuscany',
  'Lucca': 'tuscany',
  'Lecco': 'lake-como',
  'Como': 'lake-como',
  'Roma Capitale': 'rome',
  'Bari': 'puglia',
  'Brindisi': 'puglia',
  'Lecce': 'puglia',
  'Salerno': 'amalfi-coast',
  'Naples': 'amalfi-coast',
  'Milan': 'milan',
  'Venice': 'venice',
  'Palermo': 'sicily',
  'Catania': 'sicily',
};

const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Popular Wedding Venues in Italy — ${venues.length} venues with live music data`,
  description: `Browse ${venues.length} wedding venues across Italy — including typical music budgets, curfew times, guest capacities, and top bands at each venue.`,
  url: `https://${siteConfig.domain}/venues/`,
  numberOfItems: venues.length,
  isPartOf: {
    '@type': 'WebSite',
    name: siteConfig.name,
    url: `https://${siteConfig.domain}`,
  },
};
---

<BaseLayout
  title={`Popular Wedding Venues in Italy — ${venues.length} Venues with Live Music Data`}
  description={`Browse ${venues.length} Italian wedding venues with real data: typical music budgets, curfew times, guest capacities, and top bands at each venue.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `https://${siteConfig.domain}/` },
      { '@type': 'ListItem', position: 2, name: 'Wedding Venues in Italy' },
    ],
  })} />

  <div class="max-w-6xl mx-auto px-4 py-10">
    <!-- Hero -->
    <header class="mb-10 text-center">
      <h1 class="font-heading text-3xl md:text-4xl font-bold mb-3">Popular Wedding Venues in Italy</h1>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Real data from actual wedding bookings across <strong>{venues.length}</strong> venues —
        including typical music budgets, curfew times, and guest capacities.
      </p>
    </header>

    <!-- Quick stats -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{venues.length}</div>
        <div class="text-sm text-gray-500">Venues</div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{sortedRegions.length}</div>
        <div class="text-sm text-gray-500">Provinces</div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">200+</div>
        <div class="text-sm text-gray-500">Bands Performing</div>
      </div>
    </div>

    <!-- Browse by location -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold mb-4">Browse by Region</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {sortedRegions.map((region) => {
          const locationSlug = locationSlugMap[region.name];
          const topVenues = region.items.slice(0, 3);
          return (
            <div class="border border-gray-200 rounded-lg p-5">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="font-heading text-lg font-semibold">{region.name}</h3>
                  <p class="text-sm text-gray-500">
                    {region.items.length} venues
                  </p>
                </div>
                {locationSlug && (
                  <a href={`/venues/by-region/${locationSlug}/`} class="text-primary text-sm font-medium hover:underline whitespace-nowrap">
                    See all venues →
                  </a>
                )}
              </div>
              <ul class="space-y-2">
                {topVenues.map((venue) => {
                  const vName = venueShortName(venue.canonical_name);
                  const vTown = venueTown(venue.canonical_name);
                  return (
                    <li>
                      <a href={`/venues/${venue.slug}/`} class="flex items-center justify-between group">
                        <span class="group-hover:text-primary transition">
                          <span class="font-medium">{vName}</span>
                          {vTown && <span class="text-gray-400 text-sm ml-1">· {vTown}</span>}
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
              {region.items.length > 3 && (
                <p class="text-xs text-gray-400 mt-3">
                  +{region.items.length - 3} more venue{region.items.length - 3 !== 1 ? 's' : ''}
                </p>
              )}
            </div>
          );
        })}
      </div>
    </section>

    {/* Footer CTA */}
    <div class="text-center mt-8">
      <p class="text-gray-500 text-sm mb-4">Data based on real wedding bookings across Italy.</p>
      <a href="/enquire/" class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition">
        Get a Quote for Your Venue
      </a>
    </div>
  </div>
</BaseLayout>
