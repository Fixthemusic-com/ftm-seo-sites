---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BandCard from '../../components/BandCard.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import VideoShowcase from '../../components/VideoShowcase.astro';
import { siteConfig } from '../../lib/config';
import { getBands, getBand, getRelatedBands, getBandProfile, getBandReviews, getBandPhotos, getBandVideos } from '../../lib/api';
import type { BandProfile, BandReview } from '../../lib/api';

// Load AI-rewritten profile cache (falls back gracefully if not present)
let profilesCache: Record<string, { intro_html: string; description_html: string; set_list_html: string; faq_html: string }> = {};
try {
  const siteId = import.meta.env.SITE_ID || 'weddingbandsitaly';
  if (siteId === 'weddingbandsitaly') {
    profilesCache = (await import('../../data/profiles-weddingbandsitaly.json')).default;
  } else {
    profilesCache = (await import('../../data/profiles-weddingmusicbanditaly.json')).default;
  }
} catch {
  // No cache file yet — will use raw API content
}

// Generate static paths for all bands in the region at build time
export async function getStaticPaths() {
  try {
    const allBands = [];
    let page = 1;
    let hasMore = true;

    while (hasMore) {
      const result = await getBands({
        booked_in: siteConfig.regionId,
        page,
        page_size: 100,
      });
      allBands.push(...result.items);
      hasMore = page < result.num_pages;
      page++;
    }

    const slugSet = new Set(allBands.map((b) => b.slug));
    return allBands.map((band) => ({
      params: { slug: band.slug },
      props: { regionSlugs: [...slugSet] },
    }));
  } catch (err) {
    console.error('Failed to fetch bands for static paths:', err.message);
    return [];
  }
}

const { slug } = Astro.params;
const { regionSlugs } = Astro.props;
const regionSlugSet = new Set(regionSlugs);
const band = await getBand(slug!);

// Fetch profile, reviews, related bands, photos, and videos in parallel with graceful fallback
const [profile, reviews, rawRelatedBands, photos, videos] = await Promise.all([
  getBandProfile(slug!).catch(() => ({
    intro_rendered: '',
    description_rendered: '',
    locations_rendered: '',
    set_list_rendered: '',
    faq_rendered: '',
  }) as BandProfile),
  getBandReviews(slug!).catch(() => ({ items: [] as BandReview[], count: 0 })),
  getRelatedBands(slug!).catch(() => [] as any[]),
  getBandPhotos(slug!).catch(() => [] as any[]),
  getBandVideos(slug!).catch(() => [] as any[]),
]);

// Filter related bands to only those in the region (with pages on this site)
const relatedBands = rawRelatedBands.filter((b: any) => regionSlugSet.has(b.slug));

const priceDisplay =
  !band.hide_price && band.price_low && band.price_high
    ? `${band.currency} ${band.price_low.toLocaleString()} - ${band.price_high.toLocaleString()}`
    : !band.hide_price && band.price_low
      ? `From ${band.currency} ${band.price_low.toLocaleString()}`
      : null;

const imageUrl = band.main_photo?.large || band.main_photo?.medium || null;

// Use AI-rewritten content if cached, otherwise fall back to raw API
// IMPORTANT: use `!= null` (not `||`) because empty string '' is a valid rewritten
// value meaning "this section was intentionally left empty by the LLM". Using `||`
// would fall through to the raw API content which contains fixthemusic.com links.
const cached = profilesCache[slug!];
const introHtml = cached?.intro_html != null ? cached.intro_html : (profile.intro_rendered || '');
const descHtml = cached?.description_html != null ? cached.description_html : (profile.description_rendered || '');
const setListHtml = cached?.set_list_html != null ? cached.set_list_html : (profile.set_list_rendered || '');
const faqHtml = cached?.faq_html != null ? cached.faq_html : (profile.faq_rendered || '');

// Schema.org — MusicGroup with AggregateRating, Offer, reviews
const bandUrl = `https://${siteConfig.domain}/bands/${band.slug}/`;

// Hardcode 5 stars for all bands with reviews
const avgRating = band.reviews_count > 0 ? '5.0' : null;
const ratedReviews = reviews.items.filter((r) => r.rating != null && r.rating > 0);

// Build MusicGroup schema
const musicGroupSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: band.name,
  description: band.kicker || `${band.name} — wedding band available in Italy.`,
  image: imageUrl || undefined,
  url: bandUrl,
  genre: band.tags?.filter((t: any) => typeof t === 'string').slice(0, 5) || undefined,
  areaServed: { '@type': 'Country', name: 'Italy' },
};

if (avgRating && band.reviews_count > 0) {
  musicGroupSchema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: avgRating,
    reviewCount: band.reviews_count,
    bestRating: 5,
  };
}

// Add top 5 reviews as Review items
if (ratedReviews.length > 0) {
  musicGroupSchema.review = ratedReviews.slice(0, 5).map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.author },
    datePublished: new Date(r.time_published).toISOString().split('T')[0],
    reviewBody: r.text.length > 500 ? r.text.slice(0, 500) + '…' : r.text,
    ...(r.rating ? { reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 } } : {}),
  }));
}

if (!band.hide_price && band.price_low) {
  musicGroupSchema.makesOffer = {
    '@type': 'Offer',
    itemOffered: {
      '@type': 'Service',
      name: `${band.name} — Live Wedding Band Performance`,
      areaServed: { '@type': 'Country', name: 'Italy' },
    },
    priceSpecification: {
      '@type': 'PriceSpecification',
      priceCurrency: band.currency || 'EUR',
      ...(band.price_high
        ? { minPrice: band.price_low, maxPrice: band.price_high }
        : { price: band.price_low }),
    },
  };
}

// Parse FAQ HTML into FAQPage schema
let faqPageSchema: Record<string, any> | null = null;
if (faqHtml) {
  // FAQ content is typically <h3>Question</h3><p>Answer</p> pairs
  const faqPairs: { question: string; answer: string }[] = [];
  const faqRegex = /<h[2-4][^>]*>([\s\S]*?)<\/h[2-4]>\s*([\s\S]*?)(?=<h[2-4]|$)/gi;
  let match;
  while ((match = faqRegex.exec(faqHtml)) !== null) {
    const q = match[1].replace(/<[^>]+>/g, '').trim();
    const a = match[2].replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
    if (q && a) faqPairs.push({ question: q, answer: a });
  }
  // Fallback: try <strong>Question</strong> pattern
  if (faqPairs.length === 0) {
    const boldRegex = /<strong[^>]*>([\s\S]*?)<\/strong>\s*([\s\S]*?)(?=<strong|$)/gi;
    while ((match = boldRegex.exec(faqHtml)) !== null) {
      const q = match[1].replace(/<[^>]+>/g, '').replace(/\?$/, '').trim() + '?';
      const a = match[2].replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
      if (q.length > 5 && a) faqPairs.push({ question: q, answer: a });
    }
  }
  if (faqPairs.length > 0) {
    faqPageSchema = {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqPairs.map((p) => ({
        '@type': 'Question',
        name: p.question,
        acceptedAnswer: { '@type': 'Answer', text: p.answer },
      })),
    };
  }
}

// BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://${siteConfig.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Browse', item: `https://${siteConfig.domain}/browse/` },
    { '@type': 'ListItem', position: 3, name: band.name },
  ],
};
---

<BaseLayout
  title={`${band.name} - Wedding Band in Italy`}
  description={band.kicker || `Book ${band.name} for your Italian wedding. ${band.reviews_count} reviews.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(musicGroupSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqPageSchema && <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />}

  <article class="max-w-5xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="font-heading text-3xl md:text-4xl font-bold">{band.name}</h1>
      {band.kicker && <p class="text-lg text-gray-600 mt-2">{band.kicker}</p>}
      <div class="flex flex-wrap items-center gap-4 mt-4">
        {priceDisplay && (
          <span class="text-lg font-semibold text-primary">{priceDisplay}</span>
        )}
        {band.reviews_count > 0 && (
          <div class="flex items-center gap-1">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span class="text-gray-500">{band.reviews_count} reviews</span>
          </div>
        )}
        {band.location && (
          <span class="text-gray-500">{band.location}</span>
        )}
      </div>
    </div>

    <!-- Profile image -->
    {imageUrl && (
      <div class="rounded-xl overflow-hidden mb-8">
        <img
          src={imageUrl}
          alt={band.name}
          class="w-full max-h-96 object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )}

    <!-- Tags -->
    {band.tags && band.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {band.tags.map((tag: any) => (
          <span class="px-3 py-1 bg-gray-100 rounded-full text-sm text-gray-600">{tag.label || tag}</span>
        ))}
      </div>
    )}

    <!-- Booking stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      {band.bookings_count > 0 && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-primary">{band.bookings_count}</p>
          <p class="text-sm text-gray-500">Bookings</p>
        </div>
      )}
      {band.reviews_count > 0 && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-primary">{band.reviews_count}</p>
          <p class="text-sm text-gray-500">Reviews</p>
        </div>
      )}
      {band.insured && (
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-green-600">&#10003;</p>
          <p class="text-sm text-gray-500">Insured</p>
        </div>
      )}
    </div>

    <!-- Profile sections -->
    {introHtml && (
      <div class="prose prose-lg max-w-none mb-8">
        <h2>About {band.name}</h2>
        <Fragment set:html={introHtml} />
      </div>
    )}

    {descHtml && (
      <div class="prose prose-lg max-w-none mb-8">
        <Fragment set:html={descHtml} />
      </div>
    )}

    <!-- Photo Gallery -->
    <PhotoGallery photos={photos} bandName={band.name} />

    <!-- Video Showcase -->
    <VideoShowcase videos={videos} bandName={band.name} />

    {setListHtml && (
      <div class="prose prose-lg max-w-none mb-8">
        <h2>Set List</h2>
        <Fragment set:html={setListHtml} />
      </div>
    )}

    {faqHtml && (
      <div class="prose prose-lg max-w-none mb-8">
        <h2>FAQ</h2>
        <Fragment set:html={faqHtml} />
      </div>
    )}

    <!-- Reviews -->
    {reviews.count > 0 && (
      <section class="mb-8" data-nosnippet>
        <h2 class="font-heading text-2xl font-bold mb-6">Reviews ({reviews.count})</h2>
        <div class="space-y-6">
          {reviews.items.slice(0, 10).map((review) => {
            const pubDate = new Date(review.time_published);
            const formattedDate = pubDate.toLocaleString('en-US', { month: 'long', year: 'numeric' });
            return (
              <div class="border-b border-gray-200 pb-6">
                <div class="mb-2">
                  <span class="font-bold">{review.author}</span>
                  {review.event_string && (
                    <span class="text-gray-500 ml-2">{review.event_string}</span>
                  )}
                </div>
                <p class="text-gray-700 mb-2">{review.text}</p>
                <p class="text-sm text-gray-400">{formattedDate}</p>
                {review.response && (
                  <div class="bg-gray-100 rounded-lg p-4 mt-3">
                    <p class="text-sm"><span class="font-semibold">Band replied:</span> <Fragment set:html={review.response.message_rendered} /></p>
                  </div>
                )}
              </div>
            );
          })}
        </div>
        {reviews.count > 10 && (
          <p class="text-gray-500 mt-4 text-center">Showing 10 of {reviews.count} reviews</p>
        )}
      </section>
    )}

    <!-- CTA -->
    <div class="bg-primary rounded-xl p-8 text-white text-center">
      <h2 class="font-heading text-2xl font-bold mb-3">
        Interested in booking {band.name}?
      </h2>
      <p class="opacity-90 mb-6">Send an enquiry and we'll get back to you within 24 hours.</p>
      <a
        href={`/enquire/?band=${band.slug}`}
        class="bg-accent text-white px-8 py-3 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity inline-block"
      >
        Enquire About {band.name}
      </a>
    </div>

    <!-- Related bands -->
    {relatedBands && relatedBands.length > 0 && (
      <section class="mt-12">
        <h2 class="font-heading text-2xl font-bold mb-6">Similar Bands</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {relatedBands.slice(0, 4).map((b: any) => (
            <BandCard band={b} />
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
