---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BandCard from '../../components/BandCard.astro';
import { siteConfig } from '../../lib/config';
import { getBands, getCategories } from '../../lib/api';
import type { Band, BandCategory, PaginatedResponse } from '../../lib/types';

export async function getStaticPaths() {
  const PAGE_SIZE = 24;
  const MAX_API_PAGES = 50; // API enforces a max page limit
  const [firstPage, categories] = await Promise.all([
    getBands({ home_region: siteConfig.regionId, page_size: PAGE_SIZE }),
    getCategories(),
  ]);

  const paths: { params: { path: string | undefined }; props: any }[] = [];

  // --- "All" pages (no category filter) ---
  const allNumPages = Math.min(firstPage.num_pages, MAX_API_PAGES);
  // Page 1: /browse/ -- pass pre-fetched bands to avoid re-fetching
  paths.push({
    params: { path: undefined },
    props: { page: 1, numPages: allNumPages, totalCount: firstPage.count, category: null, categories, prefetchedBands: firstPage.items },
  });
  for (let p = 2; p <= allNumPages; p++) {
    paths.push({
      params: { path: String(p) },
      props: { page: p, numPages: allNumPages, totalCount: firstPage.count, category: null, categories, prefetchedBands: null },
    });
  }

  // --- Category pages (fetch page 1 of each in parallel) ---
  const catResults = await Promise.all(
    categories.map((cat) =>
      getBands({ home_region: siteConfig.regionId, category: cat.slug, page_size: PAGE_SIZE })
        .then((result) => ({ cat, result }))
    )
  );

  // Build a map of category slug -> actual count (filtered by home_region)
  const categoryCounts: Record<string, number> = {};
  for (const { cat, result } of catResults) {
    categoryCounts[cat.slug] = result.count;
  }

  for (const { cat, result } of catResults) {
    const catNumPages = Math.min(result.num_pages, MAX_API_PAGES);

    // Page 1: /browse/luxury-showbands/ -- pass pre-fetched bands
    paths.push({
      params: { path: cat.slug },
      props: { page: 1, numPages: catNumPages, totalCount: result.count, category: cat, categories, prefetchedBands: result.items, categoryCounts },
    });
    for (let p = 2; p <= catNumPages; p++) {
      paths.push({
        params: { path: `${cat.slug}/${p}` },
        props: { page: p, numPages: catNumPages, totalCount: result.count, category: cat, categories, prefetchedBands: null, categoryCounts },
      });
    }
  }

  // Also add categoryCounts to "All" pages
  paths.forEach((p) => {
    if (!p.props.categoryCounts) {
      p.props.categoryCounts = categoryCounts;
    }
  });

  return paths;
}

interface Props {
  page: number;
  numPages: number;
  totalCount: number;
  category: BandCategory | null;
  categories: BandCategory[];
  prefetchedBands: Band[] | null;
  categoryCounts: Record<string, number>;
}

const { page, numPages, totalCount, category, categories, prefetchedBands, categoryCounts } = Astro.props;
const PAGE_SIZE = 24;

// Use prefetched bands for page 1, fetch for other pages
let bands: Band[];
if (prefetchedBands) {
  bands = prefetchedBands;
} else {
  const result = await getBands({
    home_region: siteConfig.regionId,
    category: category?.slug,
    page,
    page_size: PAGE_SIZE,
  });
  bands = result.items;
}

// Build URLs
function browseUrl(catSlug?: string, pageNum?: number): string {
  if (catSlug && pageNum && pageNum > 1) return `/browse/${catSlug}/${pageNum}/`;
  if (catSlug) return `/browse/${catSlug}/`;
  if (pageNum && pageNum > 1) return `/browse/${pageNum}/`;
  return '/browse/';
}

const currentCategorySlug = category?.slug || null;

// Title / description
const categoryName = category?.name || 'Wedding Entertainment';
const pageTitle = page > 1
  ? `Browse ${categoryName} - Page ${page}`
  : `Browse Wedding Bands & Entertainment in Italy`;
const pageDescription = category
  ? `Browse ${totalCount}+ ${category.name} available in Italy. Filter by category, budget, and style.`
  : `Browse ${totalCount}+ wedding bands and entertainment acts available in Italy. Filter by category, budget, and style.`;

// BreadcrumbList schema for browse pages
const browseBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://${siteConfig.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Browse', item: `https://${siteConfig.domain}/browse/` },
    ...(category ? [{ '@type': 'ListItem' as const, position: 3, name: category.name }] : []),
  ],
};

// Pagination: show max 7 page links (fits mobile without overflow)
const maxPaginationLinks = 7;
let startPage = Math.max(1, page - Math.floor(maxPaginationLinks / 2));
let endPage = Math.min(numPages, startPage + maxPaginationLinks - 1);
if (endPage - startPage + 1 < maxPaginationLinks) {
  startPage = Math.max(1, endPage - maxPaginationLinks + 1);
}
const pageNumbers = Array.from({ length: endPage - startPage + 1 }, (_, i) => startPage + i);

// Popular locations for search (label + Google Place ID for geocoded search)
const popularLocations = [
  { label: 'Rome', placeId: 'ChIJu46S-ZZhLxMROG5lkwZ3D7k' },
  { label: 'Florence', placeId: 'ChIJrdbSgKZWKhMRAyrH7xd51ZM' },
  { label: 'Tuscany', placeId: 'ChIJezSAEFMr1BIRq1kgW7rDxro' },
  { label: 'Milan', placeId: 'ChIJ53USP0nBhkcRjQ50xhPN_zw' },
  { label: 'Amalfi Coast', placeId: 'ChIJoXFMw62VOxMR3ExPyRTP6Ew' },
  { label: 'Lake Como', placeId: 'ChIJ92ILgjI9hEcR4OGY6OrEQD4' },
  { label: 'Puglia', placeId: 'ChIJ3ZO5jSvkNhMRj3wk-HC6bzk' },
  { label: 'Venice', placeId: 'ChIJiT3W8dqxfkcRLxCSvfDGo3s' },
];

// API config for client-side search
const apiBase = import.meta.env.FTM_API_BASE || 'https://www.fixthemusic.com';
const regionId = siteConfig.regionId;
const categorySlugs = categories.filter(cat => (categoryCounts[cat.slug] ?? cat.num_bands) > 0).map(cat => cat.slug);
const googleApiKey = import.meta.env.PUBLIC_NEXT_PUBLIC_GOOGLE_API_KEY || '';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(browseBreadcrumb)} />
  <section class="py-10">
    <div class="max-w-7xl mx-auto px-4">
      <h1 id="browse-heading" class="font-heading text-3xl md:text-4xl font-bold mb-2">
        {category ? `Browse ${category.name}` : 'Browse Wedding Entertainment'}
      </h1>
      <p id="browse-subtitle" class="text-gray-600 mb-6">
        {totalCount} acts{category ? ` in ${category.name}` : ' available in Italy'}
        {page > 1 && ` -- Page ${page}`}
      </p>

      <!-- Search bar -->
      <div class="mb-6">
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="band-search"
            type="search"
            placeholder="Search by location or band name..."
            autocomplete="off"
            class="w-full pl-11 pr-10 py-3 border border-gray-300 rounded-xl text-base focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow"
          />
          <button
            id="search-clear"
            class="absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors hidden"
            aria-label="Clear search"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="flex gap-x-1 gap-y-1 mt-2.5 text-sm flex-wrap items-center">
          <span class="text-gray-400 mr-1">Popular:</span>
          {popularLocations.map((loc) => (
            <button
              class="search-suggestion px-2.5 py-0.5 rounded-full bg-gray-100 text-gray-600 hover:bg-primary hover:text-white transition-colors cursor-pointer"
              data-query={loc.label}
              data-place-id={loc.placeId}
            >
              {loc.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Search location badge (shown when using geocoded location search) -->
      <div id="location-badge" class="hidden mb-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue-50 text-blue-700 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span id="location-badge-text">Searching near <span id="location-badge-name"></span></span>
          <button id="location-badge-clear" class="ml-1 text-blue-400 hover:text-blue-600 cursor-pointer" aria-label="Clear location search">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </span>
      </div>

      <!-- Search status bar (hidden by default, shown during active search) -->
      <div id="search-status" class="hidden mb-6">
        <div class="flex items-center justify-between">
          <p id="search-status-text" class="text-gray-600 text-sm"></p>
          <button id="search-status-clear" class="text-sm text-primary hover:underline cursor-pointer">
            Clear search
          </button>
        </div>
      </div>

      <!-- Loading skeleton (hidden by default) -->
      <div id="search-loading" class="hidden mb-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {Array.from({ length: 8 }).map(() => (
            <div class="bg-white rounded-xl overflow-hidden shadow-sm animate-pulse">
              <div class="aspect-[4/3] bg-gray-200"></div>
              <div class="p-4">
                <div class="h-5 bg-gray-200 rounded w-3/4 mb-2"></div>
                <div class="h-4 bg-gray-200 rounded w-1/2 mb-3"></div>
                <div class="h-3 bg-gray-200 rounded w-1/3"></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- No results (hidden by default) -->
      <div id="search-no-results" class="hidden py-16 text-center">
        <svg class="mx-auto w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <p class="text-lg text-gray-500 mb-2">No bands found matching "<span id="no-results-query"></span>"</p>
        <p class="text-sm text-gray-400">Try a different search or <a href="/browse/" class="text-primary hover:underline">browse all categories</a>.</p>
      </div>

      <!-- Category filters -->
      <div id="category-filters" class="flex flex-wrap gap-3 mb-8" data-current-category={currentCategorySlug || ''}>
        <a
          href="/browse/"
          data-category=""
          data-count-default={totalCount}
          class:list={[
            'category-pill px-4 py-2 rounded-full text-sm font-medium transition-colors',
            !currentCategorySlug
              ? 'bg-primary text-white'
              : 'bg-gray-100 text-gray-700 hover:bg-gray-200',
          ]}
        >
          All (<span class="category-count-num">{totalCount}</span>)
        </a>
        {categories.slice(0, 10).filter(cat => (categoryCounts[cat.slug] ?? cat.num_bands) > 0).map((cat) => {
          const count = categoryCounts[cat.slug] ?? cat.num_bands;
          return (
            <a
              href={browseUrl(cat.slug)}
              data-category={cat.slug}
              data-count-default={count}
              class:list={[
                'category-pill px-4 py-2 rounded-full text-sm font-medium transition-colors',
                currentCategorySlug === cat.slug
                  ? 'bg-primary text-white'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200',
              ]}
            >
              {cat.name} (<span class="category-count-num">{count}</span>)
            </a>
          );
        })}
      </div>

      <!-- Band grid -->
      <div id="band-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {bands.map((band) => (
          <BandCard band={band} />
        ))}
      </div>

      <!-- Search results grid (hidden by default, replaces band-grid during search) -->
      <div id="search-results-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      </div>

      <!-- Pagination -->
      {numPages > 1 && (
        <nav id="pagination" class="mt-12 flex justify-center items-center gap-1.5 sm:gap-2 flex-wrap" aria-label="Pagination">
          {page > 1 && (
            <a
              href={browseUrl(currentCategorySlug || undefined, page - 1)}
              class="px-2.5 sm:px-3 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors"
              aria-label="Previous page"
            >
              &larr;
            </a>
          )}
          {pageNumbers.map((p) => (
            <a
              href={browseUrl(currentCategorySlug || undefined, p)}
              class:list={[
                'w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors',
                p === page
                  ? 'bg-primary text-white'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200',
              ]}
              aria-current={p === page ? 'page' : undefined}
            >
              {p}
            </a>
          ))}
          {page < numPages && (
            <a
              href={browseUrl(currentCategorySlug || undefined, page + 1)}
              class="px-2.5 sm:px-3 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors"
              aria-label="Next page"
            >
              &rarr;
            </a>
          )}
        </nav>
      )}
    </div>
  </section>

  <!-- Client-side search script with Google Places Autocomplete -->
  <script define:vars={{ apiBase, regionId, categorySlugs, googleApiKey }}></script>
  <script>
    (function() {
      const searchInput = document.getElementById('band-search');
      const clearBtn = document.getElementById('search-clear');
      const searchStatus = document.getElementById('search-status');
      const searchStatusText = document.getElementById('search-status-text');
      const searchStatusClear = document.getElementById('search-status-clear');
      const searchLoading = document.getElementById('search-loading');
      const searchNoResults = document.getElementById('search-no-results');
      const noResultsQuery = document.getElementById('no-results-query');
      const bandGrid = document.getElementById('band-grid');
      const searchResultsGrid = document.getElementById('search-results-grid');
      const pagination = document.getElementById('pagination');
      const categoryFilters = document.getElementById('category-filters');
      const browseSubtitle = document.getElementById('browse-subtitle');
      const locationBadge = document.getElementById('location-badge');
      const locationBadgeName = document.getElementById('location-badge-name');
      const locationBadgeClear = document.getElementById('location-badge-clear');

      let debounceTimer;
      let countAbortController = null;
      let currentAbortController = null;
      let isSearchActive = false;

      // Location search state
      let selectedPlaceId = null;   // Google Place ID when location-selected
      let selectedPlaceName = null; // Display name for the location badge
      let autocomplete = null;      // Google Places Autocomplete instance
      let autocompletePending = false; // true while user is typing before autocomplete resolves

      // --- Google Places Autocomplete setup ---

      function loadGooglePlaces() {
        if (typeof google !== 'undefined' && google.maps && google.maps.places) {
          initAutocomplete();
          return;
        }
        const script = document.createElement('script');
        script.src = `https://maps.googleapis.com/maps/api/js?key=${googleApiKey}&libraries=places&callback=__onPlacesLoaded&language=en&loading=async`;
        script.async = true;
        window.__onPlacesLoaded = function() {
          initAutocomplete();
        };
        document.head.appendChild(script);
      }

      function initAutocomplete() {
        if (autocomplete) return;
        autocomplete = new google.maps.places.Autocomplete(searchInput, {
          types: ['(regions)'],
          fields: ['place_id', 'formatted_address', 'name'],
          componentRestrictions: { country: 'it' },
          strictBounds: false,
        });
        autocomplete.addListener('place_changed', function() {
          const place = autocomplete.getPlace();
          if (place.place_id) {
            selectedPlaceId = place.place_id;
            selectedPlaceName = place.formatted_address || place.name || searchInput.value;
            autocompletePending = false;
            showLocationBadge(selectedPlaceName);
            clearTimeout(debounceTimer);
            performSearch(searchInput.value.trim(), true);
          }
        });
      }

      function showLocationBadge(name) {
        locationBadgeName.textContent = name;
        locationBadge.classList.remove('hidden');
      }

      function hideLocationBadge() {
        locationBadge.classList.add('hidden');
        selectedPlaceId = null;
        selectedPlaceName = null;
      }

      // --- DOM helpers ---

      function getActiveCategory() {
        return categoryFilters?.dataset.currentCategory || '';
      }

      function updateCategoryCounts(counts) {
        document.querySelectorAll('.category-pill').forEach((pill) => {
          const slug = pill.dataset.category;
          const countNum = pill.querySelector('.category-count-num');
          const newCount = counts[slug];
          if (newCount == null) return;
          countNum.textContent = newCount;
          if (newCount === 0) { pill.classList.add('hidden'); } else { pill.classList.remove('hidden'); }
        });
      }

      function resetCategoryCounts() {
        document.querySelectorAll('.category-pill').forEach((pill) => {
          const countNum = pill.querySelector('.category-count-num');
          const defaultCount = parseInt(pill.dataset.countDefault, 10);
          countNum.textContent = defaultCount;
          if (defaultCount === 0) { pill.classList.add('hidden'); } else { pill.classList.remove('hidden'); }
        });
      }

      // --- Category count fetching (supports both text & location search) ---

      async function fetchSearchCategoryCounts(query, placeId, signal) {
        const baseParams = { home_region: String(regionId), page_size: '1' };
        if (placeId) {
          baseParams.location = placeId;
        } else {
          baseParams.search = query;
        }

        const fetches = [
          // "All" (no category filter)
          fetch(`${apiBase}/api-v2/bands?${new URLSearchParams(baseParams)}`, { signal })
            .then(r => r.json())
            .then(d => ({ slug: '', count: d.count || 0 }))
            .catch(() => ({ slug: '', count: 0 })),
          // Per-category
          ...categorySlugs.map(slug => {
            const p = { ...baseParams, category: slug };
            return fetch(`${apiBase}/api-v2/bands?${new URLSearchParams(p)}`, { signal })
              .then(r => r.json())
              .then(d => ({ slug, count: d.count || 0 }))
              .catch(() => ({ slug, count: 0 }));
          }),
        ];
        const results = await Promise.all(fetches);
        const counts = {};
        for (const r of results) { counts[r.slug] = r.count; }
        return counts;
      }

      // --- Band card rendering ---

      function renderBandCard(band) {
        const hidePrice = band.hide_price;
        let priceDisplay = '';
        if (!hidePrice && band.price_low && band.price_high) {
          priceDisplay = `${band.currency} ${band.price_low.toLocaleString()} - ${band.price_high.toLocaleString()}`;
        } else if (!hidePrice && band.price_low) {
          priceDisplay = `From ${band.currency} ${band.price_low.toLocaleString()}`;
        }
        const imageUrl = band.main_photo?.small || band.main_photo?.medium || null;
        const imagePlaceholder = `<div class="w-full h-full flex items-center justify-center text-gray-400"><svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg></div>`;
        const imageHtml = imageUrl
          ? `<img src="${imageUrl}" alt="${band.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />`
          : imagePlaceholder;
        const reviewsHtml = band.reviews_count > 0
          ? `<svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><span class="text-xs text-gray-400">${band.reviews_count} reviews</span>`
          : '';
        const priceHtml = priceDisplay ? `<span class="text-sm font-medium text-gray-600">${priceDisplay}</span>` : '';
        const locationHtml = band.location ? `<p class="text-xs text-gray-400 mt-2">${band.location}</p>` : '';
        return `<a href="/bands/${band.slug}/" class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300">
          <div class="aspect-[4/3] overflow-hidden bg-gray-100">${imageHtml}</div>
          <div class="p-4">
            <h3 class="font-heading font-semibold text-lg group-hover:text-primary transition-colors">${band.name}</h3>
            ${band.kicker ? `<p class="text-sm text-gray-500 mt-1 line-clamp-1">${band.kicker}</p>` : ''}
            <div class="flex items-center justify-between mt-3"><div class="flex items-center gap-1">${reviewsHtml}</div>${priceHtml}</div>
            ${locationHtml}
          </div>
        </a>`;
      }

      // --- UI state management ---

      function showSearchState(state) {
        searchLoading.classList.toggle('hidden', state !== 'loading');
        searchNoResults.classList.toggle('hidden', state !== 'no-results');
        searchResultsGrid.classList.toggle('hidden', state !== 'results');
        bandGrid.classList.toggle('hidden', state !== 'idle');
        if (pagination) pagination.classList.toggle('hidden', state !== 'idle');
        searchStatus.classList.toggle('hidden', state === 'idle');
        isSearchActive = state !== 'idle';
      }

      // --- Core search ---
      // placeId: if set, use location-based (geocoded) search; otherwise text search

      async function performSearch(query, updateCounts = true) {
        if (!query.trim() && !selectedPlaceId) {
          clearSearch();
          return;
        }

        clearBtn.classList.remove('hidden');

        if (currentAbortController) currentAbortController.abort();
        currentAbortController = new AbortController();

        showSearchState('loading');

        const params = new URLSearchParams({ home_region: String(regionId), page_size: '48' });

        if (selectedPlaceId) {
          // Geocoded location search — backend resolves Place ID → Region polygon or geocode point
          params.set('location', selectedPlaceId);
          params.set('location_text', selectedPlaceName || query);
        } else {
          // Text-based search (band name / keyword)
          params.set('search', query);
        }

        const activeCategory = getActiveCategory();
        if (activeCategory) params.set('category', activeCategory);

        try {
          const res = await fetch(`${apiBase}/api-v2/bands?${params}`, {
            signal: currentAbortController.signal,
          });
          const data = await res.json();

          if (data.items && data.items.length > 0) {
            searchResultsGrid.innerHTML = data.items.map(renderBandCard).join('');
            const catLabel = activeCategory ? ' in this category' : '';
            if (selectedPlaceId) {
              searchStatusText.textContent = `${data.count} act${data.count !== 1 ? 's' : ''} near "${selectedPlaceName}"${catLabel}`;
            } else {
              searchStatusText.textContent = `${data.count} act${data.count !== 1 ? 's' : ''} matching "${query}"${catLabel}`;
            }
            showSearchState('results');
          } else {
            noResultsQuery.textContent = selectedPlaceName || query;
            searchStatusText.textContent = `No results${selectedPlaceId ? ` near "${selectedPlaceName}"` : ` for "${query}"`}`;
            showSearchState('no-results');
          }

          // Update URL
          const url = new URL(window.location);
          if (selectedPlaceId) {
            url.searchParams.set('location', selectedPlaceId);
            url.searchParams.set('location_text', selectedPlaceName || query);
            url.searchParams.delete('search');
          } else {
            url.searchParams.set('search', query);
            url.searchParams.delete('location');
            url.searchParams.delete('location_text');
          }
          history.replaceState(null, '', url);

          // Fetch and update category counts in parallel (non-blocking)
          if (updateCounts) {
            if (countAbortController) countAbortController.abort();
            countAbortController = new AbortController();
            fetchSearchCategoryCounts(query, selectedPlaceId, countAbortController.signal)
              .then(counts => updateCategoryCounts(counts))
              .catch(() => {});
          }

        } catch (err) {
          if (err.name === 'AbortError') return;
          console.error('Search failed:', err);
          showSearchState('idle');
        }
      }

      function clearSearch() {
        searchInput.value = '';
        clearBtn.classList.add('hidden');
        showSearchState('idle');
        searchResultsGrid.innerHTML = '';
        hideLocationBadge();
        resetCategoryCounts();

        if (countAbortController) { countAbortController.abort(); countAbortController = null; }
        if (currentAbortController) { currentAbortController.abort(); currentAbortController = null; }

        const url = new URL(window.location);
        url.searchParams.delete('search');
        url.searchParams.delete('location');
        url.searchParams.delete('location_text');
        history.replaceState(null, '', url);

        searchInput.focus();
      }

      // --- Event listeners ---

      // Text input: clear location selection, debounce text search
      searchInput.addEventListener('input', function() {
        // If the user types, invalidate any previously selected location
        // (Autocomplete's place_changed fires after this when they pick a result)
        if (selectedPlaceId) {
          hideLocationBadge();
        }
        autocompletePending = true;
        const val = searchInput.value;
        clearBtn.classList.toggle('hidden', !val);
        clearTimeout(debounceTimer);
        if (!val.trim()) {
          clearSearch();
          return;
        }
        debounceTimer = setTimeout(() => {
          // Only fire text search if autocomplete hasn't resolved a place
          if (autocompletePending) performSearch(val, true);
        }, 400);
      });

      clearBtn.addEventListener('click', clearSearch);
      searchStatusClear.addEventListener('click', clearSearch);

      // Location badge clear button
      locationBadgeClear.addEventListener('click', function() {
        hideLocationBadge();
        clearSearch();
      });

      // Popular location buttons — use Place ID for geocoded search
      document.querySelectorAll('.search-suggestion').forEach(function(btn) {
        btn.addEventListener('click', function() {
          clearTimeout(debounceTimer);
          autocompletePending = false;
          const query = btn.dataset.query;
          const placeId = btn.dataset.placeId;
          searchInput.value = query;
          clearBtn.classList.remove('hidden');

          if (placeId) {
            selectedPlaceId = placeId;
            selectedPlaceName = query;
            showLocationBadge(query);
            performSearch(query, true);
          } else {
            hideLocationBadge();
            performSearch(query, true);
          }
        });
      });

      // Category pill clicks during active search
      document.querySelectorAll('.category-pill').forEach(function(pill) {
        pill.addEventListener('click', function(e) {
          const query = searchInput.value.trim();
          if (!query && !selectedPlaceId) return; // no search active
          e.preventDefault();

          const clickedCategory = pill.dataset.category;
          const countNum = pill.querySelector('.category-count-num');
          if (countNum && parseInt(countNum.textContent, 10) === 0) return;

          document.querySelectorAll('.category-pill').forEach(function(p) {
            p.classList.remove('bg-primary', 'text-white');
            p.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
          });
          pill.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
          pill.classList.add('bg-primary', 'text-white');

          categoryFilters.dataset.currentCategory = clickedCategory;
          performSearch(query, false);
        });
      });

      // --- Init ---

      // Load Google Places API
      if (googleApiKey) {
        loadGooglePlaces();
      }

      // Restore search from URL params on page load
      const urlParams = new URLSearchParams(window.location.search);
      const initialLocation = urlParams.get('location');
      const initialLocationText = urlParams.get('location_text');
      const initialSearch = urlParams.get('search');

      if (initialLocation) {
        // Restore geocoded location search
        searchInput.value = initialLocationText || '';
        selectedPlaceId = initialLocation;
        selectedPlaceName = initialLocationText || '';
        clearBtn.classList.remove('hidden');
        showLocationBadge(selectedPlaceName);
        performSearch(initialLocationText || '', true);
      } else if (initialSearch) {
        searchInput.value = initialSearch;
        clearBtn.classList.remove('hidden');
        performSearch(initialSearch, true);
      }
    })();
  </script>
</BaseLayout>
