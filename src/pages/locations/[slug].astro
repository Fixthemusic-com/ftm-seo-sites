---
import { getCollection } from 'astro:content';
import LocationLayout from '../../layouts/LocationLayout.astro';
import { getBands, getVenues, getRegionVenueReviews } from '../../lib/api';
import { siteConfig } from '../../lib/config';
import type { VenueListItem } from '../../lib/types';
import type { VenueReviewList } from '../../lib/api';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkHtml from 'remark-html';

export async function getStaticPaths() {
  try {
    const locations = await getCollection('locations');
    return locations.map((location) => ({
      params: { slug: location.slug },
      props: { location },
    }));
  } catch (error) {
    console.error('Failed to generate static paths for locations:', error);
    return [];
  }
}

const { location } = Astro.props;
const { data } = location;

// Split MDX body at the 3rd h2: lead (shown above reviews/bands) vs body (collapsed below)
const rawBody = location.body || '';
const headings = [...rawBody.matchAll(/^## /gm)];
const splitAt = headings.length >= 3 ? headings[2].index : rawBody.length;
const leadMd = rawBody.slice(0, splitAt).trim();
const bodyMd = rawBody.slice(splitAt).trim();

const processor = unified().use(remarkParse).use(remarkHtml);
const leadHtml = String(await processor.process(leadMd));
const bodyHtml = bodyMd ? String(await processor.process(bodyMd)) : '';

// Fetch bands for this location's sub-region
let bands: any[] = [];
let totalBands = 0;
try {
  const result = await getBands({
    region: data.regionId,
    page_size: 8,
  });
  bands = result.items;
  totalBands = result.count;
} catch (e) {
  // Graceful fallback — page still renders without featured bands
  console.warn(`Could not fetch bands for ${data.regionName}:`, e);
}

// Fetch venues for this location's region
let venues: VenueListItem[] = [];
try {
  venues = await getVenues({
    region_id: data.regionId,
    min_bookings: 5,
    limit: 20,
  });
} catch (e) {
  console.warn(`Could not fetch venues for ${data.regionName}:`, e);
}

// Fetch venue reviews for this region
let regionReviews: VenueReviewList = { items: [], count: 0 };
try {
  regionReviews = await getRegionVenueReviews(data.regionId, 10);
} catch (e) {
  // Reviews may not exist for all regions
}
---

<LocationLayout
  title={data.title}
  description={data.description}
  heroTitle={data.heroTitle}
  heroSubtitle={data.heroSubtitle}
  regionName={data.regionName}
  region={data.region}
  bands={bands}
  totalBands={totalBands}
  venues={venues}
  regionReviews={regionReviews}
  leadHtml={leadHtml}
  bodyHtml={bodyHtml}
/>
