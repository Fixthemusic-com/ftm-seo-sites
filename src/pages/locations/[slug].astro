---
import { getCollection } from 'astro:content';
import LocationLayout from '../../layouts/LocationLayout.astro';
import { getBands, getVenues, getRegionVenueReviews } from '../../lib/api';
import { siteConfig } from '../../lib/config';
import type { VenueListItem } from '../../lib/types';
import type { VenueReviewList } from '../../lib/api';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { slug: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
const { Content } = await location.render();
const { data } = location;

// Fetch bands for this location's sub-region
let bands: any[] = [];
let totalBands = 0;
try {
  const result = await getBands({
    region: data.regionId,
    page_size: 8,
  });
  bands = result.items;
  totalBands = result.count;
} catch (e) {
  // Graceful fallback — page still renders without featured bands
  console.warn(`Could not fetch bands for ${data.regionName}:`, e);
}

// Fetch venues for this location's region
let venues: VenueListItem[] = [];
try {
  venues = await getVenues({
    region_id: data.regionId,
    min_bookings: 5,
    limit: 20,
  });
} catch (e) {
  console.warn(`Could not fetch venues for ${data.regionName}:`, e);
}

// Fetch venue reviews for this region
let regionReviews: VenueReviewList = { items: [], count: 0 };
try {
  regionReviews = await getRegionVenueReviews(data.regionId, 10);
} catch (e) {
  // Reviews may not exist for all regions
}
---

<LocationLayout
  title={data.title}
  description={data.description}
  heroTitle={data.heroTitle}
  heroSubtitle={data.heroSubtitle}
  regionName={data.regionName}
  region={data.region}
  bands={bands}
  totalBands={totalBands}
  venues={venues}
  regionReviews={regionReviews}
>
  <Content />
</LocationLayout>
